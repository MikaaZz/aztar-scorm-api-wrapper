{
  "name": "aztar-scorm-api-wrapper",
  "version": "1.0.0",
  "description": "Scorm API wrapper to build awesome projects",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "test": "jest --config jestconfig.json",
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\"",
    "lint": "tslint -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MikaaZz/aztar-scorm-api-wrapper.git"
  },
  "keywords": [
    "scorm",
    "api-wrapper",
    "scorm-1.2"
  ],
  "author": "M-Z",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MikaaZz/aztar-scorm-api-wrapper/issues"
  },
  "homepage": "https://github.com/MikaaZz/aztar-scorm-api-wrapper#readme",
  "devDependencies": {
    "@types/jest": "^29.1.2",
    "jest": "^29.1.2",
    "prettier": "^2.7.1",
    "ts-jest": "^29.0.3",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^4.8.4"
  }
}
